# TLS via Let's Encrypt (automatic). Requires DNS A/AAAA pointing here.

alembic.bio {
	encode gzip
	reverse_proxy frontend:3000
}

www.alembic.bio {
	redir https://alembic.bio{uri} permanent
}

api.alembic.bio {
	encode gzip
	reverse_proxy backend:8000
}

lab.alembic.bio {
	encode gzip
	# Same-origin /api/* proxy: the Vite dev server proxies /api → backend
	# locally, and we keep that contract in production by routing /api/*
	# through Caddy to the backend container. This way the lab can use
	# bare /api/agents/status URLs without ever tripping CORS.
	@api path /api/*
	reverse_proxy @api backend:8000

	reverse_proxy lab:80
}
