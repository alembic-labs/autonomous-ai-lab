# Copy to ".env" in this folder before: docker compose up -d --build

# --- Postgres (internal Docker network) ---
POSTGRES_USER=alembic
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=alembic_labs
DATABASE_URL=postgresql+asyncpg://alembic:CHANGE_SAME_AS_POSTGRES_PASSWORD@postgres:5432/alembic_labs

# --- Anthropic (agents + frontend /api/stack) ---
ANTHROPIC_API_KEY=

# --- BioLM (Boltz-2 / Chai-1) ---
BIOLMAI_TOKEN=
STRUCTURE_PROVIDER=biolm
BIOLM_BASE_URL=https://biolm.ai/api/v3
BIOLM_BOLTZ2_PATH=/boltz2/predict/
BIOLM_CHAI1_PATH=/chai1/predict/
BIOLM_TIMEOUT_SECONDS=600

# --- Backend app ---
APP_ENV=production
LOG_LEVEL=INFO
DISTILLATION_INTERVAL_MINUTES=45
ENABLE_SCHEDULER=true
ENABLE_CHAI1=true
CORS_ALLOWED_ORIGINS=https://alembic.bio
RESEARCHER_MODEL=claude-opus-4-7
STRUCTURAL_MODEL=claude-opus-4-7
LITERATURE_MODEL=claude-sonnet-4-6
CLINICAL_MODEL=claude-sonnet-4-6
COMMUNICATOR_MODEL=claude-sonnet-4-6

# Replicate (unused if STRUCTURE_PROVIDER=biolm)
REPLICATE_API_TOKEN=
BOLTZ2_MODEL_ID=
CHAI1_MODEL_ID=

# --- Next.js build args + runtime ---
NEXT_PUBLIC_API_URL=https://api.alembic.bio
NEXT_PUBLIC_LAB_3D_URL=https://lab.alembic.bio
STACK_MODEL_ID=claude-opus-4-7
