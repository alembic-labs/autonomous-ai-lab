# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Anthropic API key — used server-side by /api/stack route only
ANTHROPIC_API_KEY=sk-ant-...

# Full URL of the standalone 3D lab app (Vite). Example: https://lab.alembic.bio or http://localhost:5173
NEXT_PUBLIC_LAB_3D_URL=

# Stack Analyzer model (Claude Opus 4.7)
STACK_MODEL_ID=claude-opus-4-7
