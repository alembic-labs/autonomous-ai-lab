# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Anthropic API key — used server-side by /api/stack route only
ANTHROPIC_API_KEY=sk-ant-...

# Full URL of the standalone 3D lab app. Falls back to https://lab.alembic.bio
# when unset. Override with http://localhost:5173 to embed a local dev server.
NEXT_PUBLIC_LAB_3D_URL=https://lab.alembic.bio

# Stack Analyzer model (Claude Opus 4.7)
STACK_MODEL_ID=claude-opus-4-7
