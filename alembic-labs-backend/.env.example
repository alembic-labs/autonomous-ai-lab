# ALEMBIC LABS — backend environment template.
# Copy to .env and fill in real values for local development.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# Models — override only if needed.
RESEARCHER_MODEL=claude-opus-4-7
STRUCTURAL_MODEL=claude-opus-4-7
LITERATURE_MODEL=claude-sonnet-4-6
CLINICAL_MODEL=claude-sonnet-4-6
COMMUNICATOR_MODEL=claude-sonnet-4-6

# --- Structure prediction provider ---
# "biolm" (default, recommended) — managed Boltz-2 / Chai-1 via biolm.ai
# "replicate" — legacy fallback, only if you really want to use it
STRUCTURE_PROVIDER=biolm

# --- BioLM (https://biolm.ai) ---
# Get your token at https://biolm.ai/ui/accounts/user-api-tokens/
BIOLMAI_TOKEN=
BIOLM_BASE_URL=https://biolm.ai/api/v3
BIOLM_BOLTZ2_PATH=/boltz2/predict/
BIOLM_CHAI1_PATH=/chai1/predict/
BIOLM_TIMEOUT_SECONDS=600

# --- Replicate (legacy fallback only — leave empty if using BioLM) ---
REPLICATE_API_TOKEN=
BOLTZ2_MODEL_ID=
CHAI1_MODEL_ID=

# --- Database ---
# Default local Postgres (see README for `docker run` snippet).
DATABASE_URL=postgresql+asyncpg://alembic:alembic@localhost:5432/alembic_labs

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
# Cycle cadence — production uses 60min to keep monthly spend predictable.
DISTILLATION_INTERVAL_MINUTES=60
# Legacy always-on cross-validation. Leave false in production; the adaptive
# gate below decides per fold. Set to true only as an emergency override.
ENABLE_CHAI1=false
# Adaptive Chai-1 cross-validation. Runs Chai-1 only when Boltz-2's pLDDT
# lands in the borderline band [LOW, HIGH] — above HIGH cross-val adds no
# signal, below LOW the structure is too noisy to clarify.
ENABLE_CHAI1_ADAPTIVE=true
CHAI1_GATE_PLDDT_LOW=0.5
CHAI1_GATE_PLDDT_HIGH=0.7
ENABLE_SCHEDULER=true
PDB_STORAGE_DIR=./pdb_storage
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://alembic.bio

# --- Twitter (later phase, leave empty for now) ---
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Solana on-chain logging ---
# Master switch. Off by default — flip to true once a funded keypair is
# configured. When on, every REFINED/PROMISING/DISCARDED fold gets a
# SHA-256 hash committed via the SPL Memo program.
SOLANA_ONCHAIN_ENABLED=false
# RPC endpoint for the active cluster.
#   mainnet: https://api.mainnet-beta.solana.com
#   devnet:  https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Base58-encoded 64-byte secret key (Phantom export style). Generate via
#   solana-keygen new --no-bip39-passphrase --outfile /tmp/alembic.json
#   python -c "import json,base58;print(base58.b58encode(bytes(json.load(open('/tmp/alembic.json')))).decode())"
# Fund with ~0.5 SOL on mainnet (~$50 covers thousands of memos at ~$0.001
# each). For testing, set SOLANA_NETWORK=devnet and use the devnet faucet.
SOLANA_KEYPAIR_BASE58=
# ``mainnet`` | ``devnet`` — drives the Solscan explorer cluster suffix.
SOLANA_NETWORK=mainnet
# Treat any RPC/signing error as non-fatal so the cycle still publishes the
# fold even when Solana is degraded. Flip to false in tests.
SOLANA_FAILURE_NON_FATAL=true
# Legacy, unused — kept for backwards compatibility with older .env files.
SOLANA_KEYPAIR_PATH=
